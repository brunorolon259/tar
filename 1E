"scribe un programa que muestre las tablas de multiplicar del 1 al 10."
num= int(input("Ingresa un número del 1 al 7 y determine a que numero de la semana corresponde: "))

if num== 1:
    print("El numero corresponde al lunes")
elif num== 2:
    print("El numero corresponde al martes")
elif num== 3:
    print("El numero corresponde al  miercoles")
elif num==4:
    print("El numero corresponde al jueves")
elif num== 5:
    print("El numero corresponde al viernes")
elif num== 6:
    print("El numero corresponde al sabado")
elif num== 7:
    print("El numero corresponde al domingo")
else:
    print("Error, el numero debe estar entre el 1 y el 7")
